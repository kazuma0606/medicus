packages:
  .

-- Cabal version constraint to avoid 3.10.3.0 issue
constraints: Cabal <3.10.3 || >=3.12

-- Allow newer versions for compatibility
allow-newer: all

-- Optimization flags
package medicus-api
  ghc-options: -O2

package medicus-engine
  ghc-options: -O2

-- Test configuration
tests: True
test-show-details: direct

-- Benchmarks
benchmarks: False

-- Documentation
documentation: True
haddock-all: True

-- Build configuration
jobs: $ncpus
